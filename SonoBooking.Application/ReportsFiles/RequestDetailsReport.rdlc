          </Border>
        </Style>
      </Textbox>
      <Textbox Name="TxtApplicant">
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="مقدم لسيادتكم / " &amp; First(Fields!ApplicantName.Value, "RequestDetails") &amp; " - رقم القومي : " &amp; First(Fields!NationalId.Value, "RequestDetails")</Value>
                <Style>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Right</TextAlign>
            </Style>
