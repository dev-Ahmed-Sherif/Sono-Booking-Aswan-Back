        </Style>
      </Textbox>
      <Textbox Name="TxtRequestBody">
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="ألتمس من سيادتكم التكرم بالموافقة على الإقامة باستراحة بـ " &amp; First(Fields!DestinationGovernorate.Value, "RequestDetails") &amp; " إبتداء من : " &amp; First(Fields!StartDate.Value, "RequestDetails") &amp; " حتى : " &amp; First(Fields!EndDate.Value, "RequestDetails") &amp; " (" &amp; First(Fields!Nights.Value, "RequestDetails") &amp; " ليالي). حيث انني بحاجة لعدد " &amp; First(Fields!Apartments.Value, "RequestDetails") &amp; " شقة، " &amp; First(Fields!Rooms.Value, "RequestDetails") &amp; " غرفة، " &amp; First(Fields!Beds.Value, "RequestDetails") &amp; " سرير للأسباب الآتية:"</Value>
                <Style />
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Right</TextAlign>
            </Style>
          </Paragraph>
        </Paragraphs>
