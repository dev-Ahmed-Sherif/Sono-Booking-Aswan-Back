<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!-- WebSockets for IIS/IIS Express must be enabled in Windows Features or IIS site settings, not here (section is locked at parent level). SignalR falls back to SSE/long polling. Kestrel uses app.UseWebSockets() in Program.cs. -->
      <aspNetCore processPath="dotnet" arguments=".\SonoBooking.Api.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
